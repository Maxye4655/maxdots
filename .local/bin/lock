#!/usr/bin/env python3
import subprocess, os, sys, signal, time, random, threading
import gi
gi.require_version("Gtk", "3.0")
gi.require_version("Gdk", "3.0")
from gi.repository import Gtk, Gdk, GLib, GdkPixbuf, cairo

PID = "/tmp/lock.pid"
if os.path.exists(PID):
    old = open(PID).read().strip()
    if old and os.path.exists(f"/proc/{old}"):
        sys.exit(0)
open(PID, "w").write(str(os.getpid()))

CHARS = list(
    "字文匿秘密密码解锁登录安全保护隐藏鎖"
    "暗証番号合言葉鍵秘密暗号開く"
    "あいうえおかきくけこさしすせそ"
    "たちつてとなにぬねのはひふへほ"
    "まみむめもやゆよらりるれろわ"
    "がぎぐげござじずぜぞだぢづで"
    "どばびぶべぼぱぴぷぺぽ"
    "アイウエオカキクケコサシスセソ"
    "タチツテトナニヌネノハヒフヘホ"
    "マミムメモヤユヨラリルレロワ"
)

TMP = "/tmp/lock-screen.png"
FADE_MS = 2000
TICK_MS = 50

capture_ready = False

def capture():
    subprocess.run(["grim", "-o", "eDP-1", TMP], capture_output=True)
    global capture_ready
    capture_ready = True

threading.Thread(target=capture).start()

WAL = os.path.expanduser("~/.cache/wal/wal")
WALL = None
if os.path.exists(WAL):
    try:
        p = open(WAL).read().strip()
        if os.path.exists(p):
            WALL = p
    except Exception:
        pass

def blur_image(src, w, h):
    s = max(w / src.get_width(), h / src.get_height())
    sw = int(src.get_width() * s)
    sh = int(src.get_height() * s)
    scaled = src.scale_simple(sw, sh, GdkPixbuf.InterpType.BILINEAR)
    ox = (sw - w) // 2
    oy = (sh - h) // 2
    full = GdkPixbuf.Pixbuf.new_subpixbuf(scaled, ox, oy, w, h)
    bw = w // 12
    bh = h // 12
    return full.scale_simple(bw, bh, GdkPixbuf.InterpType.BILINEAR)

class LockScreen:
    def __init__(self):
        self.pwd = ""
        self.chars = []
        self.bg = None
        self.fade = 0.0
        self.fade_anim = 1
        self.fade_t = 0
        self.fade_dur = 28
        self.ready = False

        css = b"""
        label {
            font-family: "CodeNewRoman Nerd Font Propo", "WenQuanYi Micro Hei";
            font-size: 52px;
            color: #d0d0d0;
        }
        """
        prov = Gtk.CssProvider()
        prov.load_from_data(css)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), prov, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        self.win = Gtk.Window()
        self.win.set_decorated(False)
        self.win.fullscreen()
        self.win.set_keep_above(True)
        self.win.set_app_paintable(True)
        self.win.connect("draw", self.on_draw)
        self.win.connect("key-press-event", self.on_key)
        self.win.connect("realize", self.on_realize)

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        box.set_halign(Gtk.Align.CENTER)
        box.set_valign(Gtk.Align.CENTER)
        self.win.add(box)

        self.label = Gtk.Label()
        self.label.set_selectable(False)
        self.fail = Gtk.Label()
        self.fail.set_selectable(False)

        box.pack_start(self.label, False, False, 0)
        box.pack_start(self.fail, False, False, 0)

        self.win.show_all()

        GLib.timeout_add(16, self.anim_tick)
        GLib.timeout_add(TICK_MS, self.tick)
        GLib.timeout_add(50, self.poll_raw)

    def on_realize(self, win):
        if not WALL:
            return
        try:
            pix = GdkPixbuf.Pixbuf.new_from_file(WALL)
            w = self.win.get_allocated_width()
            h = self.win.get_allocated_height()
            if w and h:
                self.bg = blur_image(pix, w, h)
        except Exception:
            pass

    def anim_tick(self):
        if self.fade_anim == -1:
            self.fade_t += 1
            t = min(1.0, self.fade_t / self.fade_dur)
            self.fade = 1.0 - t * t
            self.win.queue_draw()
            if t >= 1.0:
                os.unlink(PID)
                Gtk.main_quit()
            return True
        if self.fade_anim == 1:
            self.fade_t += 1
            t = min(1.0, self.fade_t / self.fade_dur)
            self.fade = t * (2.0 - t)
            self.win.queue_draw()
            if t >= 1.0:
                self.fade = 1.0
                self.ready = True
                self.fade_anim = 0
                return False
            return True
        return False

    def poll_raw(self):
        if capture_ready and os.path.exists(TMP):
            try:
                w = self.win.get_allocated_width()
                h = self.win.get_allocated_height()
                if w and h:
                    raw = GdkPixbuf.Pixbuf.new_from_file(TMP)
                    self.bg = blur_image(raw, w, h)
                    self.win.queue_draw()
            except Exception:
                pass
            return False
        return True

    def on_draw(self, win, cr):
        cr.set_source_rgb(0.05, 0.05, 0.05)
        cr.paint()

        if self.bg and self.fade > 0:
            w = self.win.get_allocated_width()
            h = self.win.get_allocated_height()
            cr.save()
            cr.scale(w / self.bg.get_width(), h / self.bg.get_height())
            Gdk.cairo_set_source_pixbuf(cr, self.bg, 0, 0)
            cr.get_source().set_filter(cairo.Filter.BILINEAR)
            cr.paint()
            cr.restore()
            cr.set_source_rgba(0, 0, 0, 0.25)
            cr.paint()

        if self.fade < 1.0:
            cr.set_source_rgba(0, 0, 0, 1.0 - self.fade)
            cr.paint()

    def tick(self):
        now = time.time()
        self.chars = [(c, t) for c, t in self.chars if now - t < FADE_MS / 1000]
        self.render()
        return True

    def render(self):
        if not self.chars:
            self.label.set_text("")
            return
        parts = []
        now = time.time()
        for c, t in self.chars:
            a = 1.0 - (now - t) / (FADE_MS / 1000)
            a = max(0.05, min(1.0, a))
            parts.append(f'<span foreground="#d0d0d0" alpha="{int(a * 65535)}">{c}</span>')
        self.label.set_markup(" ".join(parts))

    def authenticate(self):
        if not self.pwd:
            return
        proc = subprocess.run(
            ["sudo", "-S", "-k", "true"],
            input=self.pwd.encode() + b"\n",
            capture_output=True,
            timeout=5,
        )
        if proc.returncode == 0:
            self.ready = False
            self.fade_anim = -1
            self.fade_t = 0
            GLib.timeout_add(16, self.anim_tick)
        else:
            self.fail.set_markup('<span foreground="#ff4444">NO</span>')
            self.pwd = ""
            self.chars = []
            self.label.set_text("")
            GLib.timeout_add(800, lambda: self.fail.set_text("") or True)

    def on_key(self, win, event):
        if not self.ready:
            return
        key = event.keyval
        if key in (Gdk.KEY_Return, Gdk.KEY_KP_Enter):
            self.authenticate()
            return
        if key == Gdk.KEY_BackSpace:
            self.pwd = self.pwd[:-1]
            if self.chars:
                self.chars.pop()
            self.render()
            return
        if key in (
            Gdk.KEY_Escape, Gdk.KEY_Cancel,
            Gdk.KEY_Control_L, Gdk.KEY_Control_R,
            Gdk.KEY_Shift_L, Gdk.KEY_Shift_R,
            Gdk.KEY_Alt_L, Gdk.KEY_Alt_R,
            Gdk.KEY_Super_L, Gdk.KEY_Super_R,
            Gdk.KEY_Caps_Lock, Gdk.KEY_Tab,
        ):
            return

        char = Gdk.keyval_to_unicode(key)
        if not char:
            return
        self.pwd += chr(char)
        self.chars.append((random.choice(CHARS), time.time()))
        if len(self.chars) > 10:
            self.chars.pop(0)
        self.render()

if __name__ == "__main__":
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    LockScreen()
    Gtk.main()
