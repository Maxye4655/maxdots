#!/usr/bin/env python3
import gi
gi.require_version("Gtk", "3.0")
gi.require_version("Gdk", "3.0")
from gi.repository import Gtk, Gdk, GLib, GdkPixbuf
import subprocess, os, random, signal, sys, time

PID = "/tmp/lock.pid"
if os.path.exists(PID):
    old = open(PID).read().strip()
    if old and os.path.exists(f"/proc/{old}"):
        sys.exit(0)
open(PID, "w").write(str(os.getpid()))

CHARS = list(
    "字文匿秘密密码解锁登录安全保护隐藏鎖"
    "暗証番号合言葉鍵秘密暗号開く"
    "あいうえおかきくけこさしすせそ"
    "たちつてとなにぬねのはひふへほ"
    "まみむめもやゆよらりるれろわ"
    "がぎぐげござじずぜぞだぢづで"
    "どばびぶべぼぱぴぷぺぽ"
    "アイウエオカキクケコサシスセソ"
    "タチツテトナニヌネノハヒフヘホ"
    "マミムメモヤユヨラリルレロワ"
)

TMP = "/tmp/lock-screen.png"
TMP_BLUR = "/tmp/lock-blur.png"
FADE_MS = 2000
TICK_MS = 50

alpha_hex = lambda f: f"{int(max(0, min(1, f)) * 65535):04x}"


class LockScreen:
    def __init__(self):
        self.pwd = ""
        self.chars = []
        self.pixbuf = None

        css = b"""
        label {
            font-family: "CodeNewRoman Nerd Font Propo";
            font-size: 52px;
            color: #d0d0d0;
        }
        """
        prov = Gtk.CssProvider()
        prov.load_from_data(css)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), prov, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        self.win = Gtk.Window()
        self.win.set_decorated(False)
        self.win.fullscreen()
        self.win.set_keep_above(True)
        self.win.set_app_paintable(True)
        self.win.connect("draw", self.on_draw)
        self.win.connect("key-press-event", self.on_key)

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        box.set_halign(Gtk.Align.CENTER)
        box.set_valign(Gtk.Align.CENTER)
        self.win.add(box)

        self.label = Gtk.Label()
        self.label.set_selectable(False)

        self.fail = Gtk.Label()
        self.fail.set_selectable(False)

        box.pack_start(self.label, False, False, 0)
        box.pack_start(self.fail, False, False, 0)

        self.win.show_all()

        GLib.idle_add(self.capture)
        GLib.timeout_add(TICK_MS, self.tick)

    def capture(self):
        ok = subprocess.run(["grim", "-o", "eDP-1", TMP], capture_output=True).returncode == 0
        if ok:
            subprocess.run(
                ["magick", TMP, "-resize", "25%", "-blur", "0x8",
                 "-resize", "400%", "-brightness-contrast", "-30x0",
                 TMP_BLUR],
                capture_output=True,
            )
        if os.path.exists(TMP_BLUR):
            self.pixbuf = GdkPixbuf.Pixbuf.new_from_file(TMP_BLUR)
            self.win.queue_draw()
        return False

    def on_draw(self, win, cr):
        if self.pixbuf:
            Gdk.cairo_set_source_pixbuf(cr, self.pixbuf, 0, 0)
        else:
            cr.set_source_rgb(0.05, 0.05, 0.05)
        cr.paint()

    def tick(self):
        now = time.time()
        self.chars = [(c, t) for c, t in self.chars if now - t < FADE_MS / 1000]
        self.render()
        return True

    def render(self):
        if not self.chars:
            self.label.set_text("")
            return
        parts = []
        now = time.time()
        for c, t in self.chars:
            a = 1.0 - (now - t) / (FADE_MS / 1000)
            a = max(0.05, min(1.0, a))
            parts.append(f'<span alpha="{alpha_hex(a)}">{c}</span>')
        self.label.set_markup(" ".join(parts))

    def authenticate(self):
        if not self.pwd:
            return
        proc = subprocess.run(
            ["sudo", "-S", "-k", "true"],
            input=self.pwd.encode() + b"\n",
            capture_output=True,
            timeout=5,
        )
        if proc.returncode == 0:
            os.unlink(PID)
            Gtk.main_quit()
        else:
            self.fail.set_markup('<span alpha="ffff" foreground="#ff4444">NO</span>')
            self.pwd = ""
            self.chars = []
            self.label.set_text("")
            GLib.timeout_add(800, lambda: self.fail.set_text("") or True)

    def on_key(self, win, event):
        key = event.keyval
        if key in (Gdk.KEY_Return, Gdk.KEY_KP_Enter):
            self.authenticate()
            return
        if key == Gdk.KEY_BackSpace:
            self.pwd = self.pwd[:-1]
            if self.chars:
                self.chars.pop()
            self.render()
            return
        if key in (
            Gdk.KEY_Escape, Gdk.KEY_Cancel,
            Gdk.KEY_Control_L, Gdk.KEY_Control_R,
            Gdk.KEY_Shift_L, Gdk.KEY_Shift_R,
            Gdk.KEY_Alt_L, Gdk.KEY_Alt_R,
            Gdk.KEY_Super_L, Gdk.KEY_Super_R,
            Gdk.KEY_Caps_Lock, Gdk.KEY_Tab,
        ):
            return

        char = Gdk.keyval_to_unicode(key)
        if not char:
            return
        self.pwd += chr(char)
        self.chars.append((random.choice(CHARS), time.time()))
        if len(self.chars) > 10:
            self.chars.pop(0)
        self.render()


if __name__ == "__main__":
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    LockScreen()
    Gtk.main()
