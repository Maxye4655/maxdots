#!/usr/bin/env python3
import subprocess, os, sys, signal, time, random, threading
import gi
gi.require_version("Gtk", "3.0")
gi.require_version("Gdk", "3.0")
from gi.repository import Gtk, Gdk, GLib, GdkPixbuf

PID = "/tmp/lock.pid"
if os.path.exists(PID):
    old = open(PID).read().strip()
    if old and os.path.exists(f"/proc/{old}"):
        sys.exit(0)
open(PID, "w").write(str(os.getpid()))

CHARS = list(
    "字文匿秘密密码解锁登录安全保护隐藏鎖"
    "暗証番号合言葉鍵秘密暗号開く"
    "あいうえおかきくけこさしすせそ"
    "たちつてとなにぬねのはひふへほ"
    "まみむめもやゆよらりるれろわ"
    "がぎぐげござじずぜぞだぢづで"
    "どばびぶべぼぱぴぷぺぽ"
    "アイウエオカキクケコサシスセソ"
    "タチツテトナニヌネノハヒフヘホ"
    "マミムメモヤユヨラリルレロワ"
)

TMP = "/tmp/lock-screen.png"
TMP_BLUR = "/tmp/lock-blur.png"
FADE_MS = 2000
TICK_MS = 50
CACHE_TTL = 30

capture_ready = False

def capture():
    subprocess.run(["grim", "-o", "eDP-1", TMP], capture_output=True)
    subprocess.run(["magick", TMP, "-resize", "50%", "-blur", "0x4",
                    "-resize", "200%", TMP_BLUR], capture_output=True)
    global capture_ready
    capture_ready = True

need_fresh = not (os.path.exists(TMP_BLUR) and time.time() - os.path.getmtime(TMP_BLUR) < CACHE_TTL)
if need_fresh:
    threading.Thread(target=capture).start()

class LockScreen:
    def __init__(self):
        self.pwd = ""
        self.chars = []
        self.raw = None
        self.blur = None
        self.fade = 0.0
        self.closing = False
        self.ready = False

        if os.path.exists(TMP_BLUR):
            try:
                self.blur = GdkPixbuf.Pixbuf.new_from_file(TMP_BLUR)
            except Exception:
                pass

        css = b"""
        label {
            font-family: "CodeNewRoman Nerd Font Propo", "WenQuanYi Micro Hei";
            font-size: 52px;
            color: #d0d0d0;
        }
        """
        prov = Gtk.CssProvider()
        prov.load_from_data(css)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), prov, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        self.win = Gtk.Window()
        self.win.set_decorated(False)
        self.win.fullscreen()
        self.win.set_keep_above(True)
        self.win.set_app_paintable(True)
        self.win.connect("draw", self.on_draw)
        self.win.connect("key-press-event", self.on_key)

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        box.set_halign(Gtk.Align.CENTER)
        box.set_valign(Gtk.Align.CENTER)
        self.win.add(box)

        self.label = Gtk.Label()
        self.label.set_selectable(False)
        self.fail = Gtk.Label()
        self.fail.set_selectable(False)

        box.pack_start(self.label, False, False, 0)
        box.pack_start(self.fail, False, False, 0)

        self.win.show_all()

        GLib.timeout_add(16, self.anim_tick)
        GLib.timeout_add(TICK_MS, self.tick)

        if need_fresh:
            GLib.timeout_add(50, self.poll_raw)

    def anim_tick(self):
        if self.closing:
            if self.fade > 0:
                self.fade = max(0, self.fade - 0.10)
                self.win.queue_draw()
                return True
            os.unlink(PID)
            Gtk.main_quit()
            return False
        if self.fade < 1.0:
            self.fade = min(1.0, self.fade + 0.08)
            self.win.queue_draw()
            if self.fade >= 1.0:
                self.ready = True
                return False
            return True
        return False

    def poll_raw(self):
        if capture_ready and os.path.exists(TMP):
            try:
                self.raw = GdkPixbuf.Pixbuf.new_from_file(TMP)
                self.win.queue_draw()
            except Exception:
                pass
            return False
        return True

    def on_draw(self, win, cr):
        cr.set_source_rgb(0.05, 0.05, 0.05)
        cr.paint()

        pix = self.raw or self.blur
        if pix and self.fade > 0:
            if self.raw:
                cr.save()
                cr.scale(0.5, 0.5)
                Gdk.cairo_set_source_pixbuf(cr, self.raw, 0, 0)
                cr.paint()
                cr.restore()
            else:
                Gdk.cairo_set_source_pixbuf(cr, self.blur, 0, 0)
                cr.paint()
            cr.set_source_rgba(0, 0, 0, 0.25)
            cr.paint()

        if self.fade < 1.0:
            cr.set_source_rgba(0, 0, 0, 1.0 - self.fade)
            cr.paint()

    def tick(self):
        now = time.time()
        self.chars = [(c, t) for c, t in self.chars if now - t < FADE_MS / 1000]
        self.render()
        return True

    def render(self):
        if not self.chars:
            self.label.set_text("")
            return
        parts = []
        now = time.time()
        for c, t in self.chars:
            a = 1.0 - (now - t) / (FADE_MS / 1000)
            a = max(0.05, min(1.0, a))
            parts.append(f'<span foreground="#d0d0d0" alpha="{int(a * 65535)}">{c}</span>')
        self.label.set_markup(" ".join(parts))

    def authenticate(self):
        if not self.pwd:
            return
        proc = subprocess.run(
            ["sudo", "-S", "-k", "true"],
            input=self.pwd.encode() + b"\n",
            capture_output=True,
            timeout=5,
        )
        if proc.returncode == 0:
            self.ready = False
            self.closing = True
            GLib.timeout_add(16, self.anim_tick)
        else:
            self.fail.set_markup('<span foreground="#ff4444">NO</span>')
            self.pwd = ""
            self.chars = []
            self.label.set_text("")
            GLib.timeout_add(800, lambda: self.fail.set_text("") or True)

    def on_key(self, win, event):
        if not self.ready:
            return
        key = event.keyval
        if key in (Gdk.KEY_Return, Gdk.KEY_KP_Enter):
            self.authenticate()
            return
        if key == Gdk.KEY_BackSpace:
            self.pwd = self.pwd[:-1]
            if self.chars:
                self.chars.pop()
            self.render()
            return
        if key in (
            Gdk.KEY_Escape, Gdk.KEY_Cancel,
            Gdk.KEY_Control_L, Gdk.KEY_Control_R,
            Gdk.KEY_Shift_L, Gdk.KEY_Shift_R,
            Gdk.KEY_Alt_L, Gdk.KEY_Alt_R,
            Gdk.KEY_Super_L, Gdk.KEY_Super_R,
            Gdk.KEY_Caps_Lock, Gdk.KEY_Tab,
        ):
            return

        char = Gdk.keyval_to_unicode(key)
        if not char:
            return
        self.pwd += chr(char)
        self.chars.append((random.choice(CHARS), time.time()))
        if len(self.chars) > 10:
            self.chars.pop(0)
        self.render()

if __name__ == "__main__":
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    LockScreen()
    Gtk.main()
