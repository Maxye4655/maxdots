[global]
    monitor = 0
    follow = mouse
    geometry = "350x50-8+8"
    indicate_hidden = yes
    shrink = no
    transparency = 0
    separator_height = 2
    padding = 12
    horizontal_padding = 16
    text_icon_padding = 8
    frame_width = 1
    frame_color = "#747474"
    separator_color = frame
    sort = yes
    idle_threshold = 120
    font = "CodeNewRoman Nerd Font Propo 10"
    line_height = 0
    markup = full
    format = "<span weight='bold' size='medium'>%s</span>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    icon_position = left
    min_icon_size = 32
    max_icon_size = 60
    icon_path = /usr/share/icons/hicolor/16x16/status/:/usr/share/icons/hicolor/16x16/devices/
    sticky_history = yes
    history_length = 25
    dmenu = /usr/sbin/dmenu -p dunst:
    browser = /usr/sbin/google-chrome-stable
    corner_radius = 14
    ignore_frame = no
    override_replaces = no
    stack_duplicates = true
    hide_duplicate_count = false
    always_run_script = true
    mouse_left_click = close
    mouse_middle_click = do_action
    mouse_right_click = close_all

    # Match the pywal background color with 50% alpha
    background = "#1b0c0c80"
    foreground = "#c6c2c2"
    highlight = "#747474"

[shortcuts]
    close = mod4+shift+space
    close_all = mod4+shift+grave
    history = mod4+grave
    context = mod4+shift+period

[urgency_low]
    background = "#1b0c0c60"
    foreground = "#c6c2c2"
    timeout = 6
    frame_color = "#575757"

[urgency_normal]
    background = "#1b0c0c80"
    foreground = "#c6c2c2"
    timeout = 12
    frame_color = "#747474"

[urgency_critical]
    background = "#1b0c0c99"
    foreground = "#c6c2c2"
    timeout = 0
    frame_color = "#ababab"
